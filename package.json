{
  "name": "@maxbeatty/blog",
  "version": "1.0.0",
  "private": true,
  "description": "Max Beatty's Blog",
  "license": "ISC",
  "type": "module",
  "scripts": {
    "build": "astro build",
    "cspell": "cspell",
    "dev": "astro dev",
    "linkcheck": "mise exec -- lychee --offline --root-dir dist --exclude evil dist/",
    "markdownlint": "markdownlint-cli2",
    "new-post": "node scripts/new-post.mjs",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "preview": "astro preview",
    "test": "vitest",
    "test:e2e": "playwright test"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-packagejson"
    ]
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.5",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "cspell": "^10.0.0",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.8.2",
    "prettier-plugin-packagejson": "^3.0.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.81.1"
  }
}
