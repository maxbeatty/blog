{
  "name": "@maxbeatty/blog",
  "version": "1.0.0",
  "private": true,
  "description": "Max Beatty's Blog",
  "license": "ISC",
  "type": "module",
  "scripts": {
    "build": "astro build",
    "cspell": "cspell lint --no-must-find-files 'src/content/posts/202[6-9]-*.md' 'src/content/posts/20[3-9][0-9]-*.md'",
    "dev": "astro dev",
    "linkcheck": "mise exec -- lychee --offline --root-dir dist --exclude evil dist/",
    "markdownlint": "markdownlint-cli2",
    "new-post": "node scripts/new-post.mjs",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "preview": "astro preview",
    "test": "vitest",
    "test:e2e": "playwright test"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-packagejson"
    ]
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.6",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "cspell": "^10.0.1",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.4",
    "prettier-plugin-packagejson": "^3.0.2",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  }
}
