---
import { getCollection } from "astro:content";
import PostList from "../../components/PostList.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SimpleLayout from "../../components/SimpleLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);

  const monthMap = new Map<
    string,
    { year: string; month: string; posts: typeof posts }
  >();
  for (const post of posts) {
    const year = String(post.data.date.getFullYear());
    const month = String(post.data.date.getMonth() + 1).padStart(2, "0");
    const key = `${year}/${month}`;
    if (!monthMap.has(key)) monthMap.set(key, { year, month, posts: [] });
    monthMap.get(key)!.posts.push(post);
  }

  return [...monthMap.values()].map(({ year, month, posts }) => ({
    params: { year, month },
    props: {
      year,
      month,
      label: posts[0]!.data.date.toLocaleDateString("en-US", {
        month: "long",
        year: "numeric",
      }),
      posts: posts.sort(
        (a, b) => b.data.date.getTime() - a.data.date.getTime(),
      ),
    },
  }));
}

const { year, label, posts } = Astro.props;
---

<BaseLayout title={`${label} - Max Beatty`}>
  <SimpleLayout title={label} intro={`Articles published in ${label}.`}>
    <p class="mb-8">
      <a
        href={`/${year}/`}
        class="text-sm font-medium text-sky-500 transition hover:text-sky-600 dark:text-sky-400 dark:hover:text-sky-300"
      >
        &larr; All of {year}
      </a>
    </p>
    <PostList posts={posts} showYear={false} />
  </SimpleLayout>
</BaseLayout>
