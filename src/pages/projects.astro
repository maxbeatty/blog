---
import BaseLayout from "../layouts/BaseLayout.astro";
import SimpleLayout from "../components/SimpleLayout.astro";

const projects = [
  {
    name: "Pool",
    description: "A collaborative checking account that offers effortless shared access, expense tracking, spending limits, and debit cards for everyone",
    href: "https://poolmoney.com"
  },
  {
    name: "Cash App Pay",
    description: "A fast, free, and secure method to pay for purchases online",
    href: "https://developers.cash.app/cash-app-pay-partner-api/guides/pay-kit-sdk/pay-kit-web-overview/pay-kit-benefits"
  },
  {
    name: "Square's Web Payments SDK",
    description: "JavaScript SDK that provides a secure card entry method, along with other payment methods",
    href: "https://developer.squareup.com/docs/web-payments/overview"
  },
  {
    name: "Pass Plum",
    description:
      "A password generator that creates memorable passphrases using common English words.",
    href: "https://github.com/maxbeatty/passplum",
  },
  {
    name: "dotenv",
    description:
      "Loads environment variables from .env files. One of the most widely used packages in the Node.js ecosystem.",
    href: "https://github.com/motdotla/dotenv",
  },
  {
    name: "jsPerf",
    description: "JavaScript performance benchmark service",
    href: "https://github.com/jsperf/jsperf.com"
  }
];
---

<BaseLayout title="Projects - Max Beatty" description="Things I've built.">
  <SimpleLayout
    title="Things I've built."
    intro="A collection of projects I've worked on over the years."
  >
    <ul
        role="list"
        class="grid grid-cols-1 gap-x-12 gap-y-16 sm:grid-cols-2 lg:grid-cols-3"
      >
        {
          projects.map((project) => (
            <li class="group relative flex flex-col items-start">
              <h2 class="text-base font-semibold tracking-tight text-zinc-800 dark:text-zinc-100">
                <a href={project.href}>
                  <span class="absolute -inset-x-4 -inset-y-6 z-20 sm:-inset-x-6 sm:rounded-2xl" />
                  <span class="relative z-10">{project.name}</span>
                </a>
              </h2>
              <p class="relative z-10 mt-2 text-sm text-zinc-600 dark:text-zinc-400">
                {project.description}
              </p>
              <p
                aria-hidden="true"
                class="relative z-10 mt-4 flex items-center text-sm font-medium text-sky-500"
              >
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  aria-hidden="true"
                  class="mr-2 size-4 stroke-current"
                >
                  <path
                    d="M15.712 11.823a.75.75 0 1 0 1.06 1.06l-1.06-1.06Zm-4.95 1.768a.75.75 0 0 0 1.06-1.06l-1.06 1.06Zm-2.475-1.414a.75.75 0 1 0-1.06-1.06l1.06 1.06Zm4.95-1.768a.75.75 0 1 0-1.06 1.06l1.06-1.06Zm3.359.53-.884.884 1.06 1.06.885-.883-1.061-1.06Zm-4.95-2.12 1.414-1.415L12 6.344l-1.415 1.413 1.061 1.061Zm0 3.535a2.5 2.5 0 0 1 0-3.536l-1.06-1.06a4 4 0 0 0 0 5.656l1.06-1.06Zm4.95-4.95a2.5 2.5 0 0 1 0 3.535L17.656 12a4 4 0 0 0 0-5.657l-1.06 1.06Zm1.06-1.06a4 4 0 0 0-5.656 0l1.06 1.06a2.5 2.5 0 0 1 3.536 0l1.06-1.06Zm-7.07 7.07.176.177 1.06-1.06-.176-.177-1.06 1.06Zm-3.183-.353.884-.884-1.06-1.06-.884.883 1.06 1.06Zm4.95 2.121-1.414 1.414 1.06 1.06 1.415-1.413-1.06-1.061Zm0-3.536a2.5 2.5 0 0 1 0 3.536l1.06 1.06a4 4 0 0 0 0-5.656l-1.06 1.06Zm-4.95 4.95a2.5 2.5 0 0 1 0-3.535L6.344 12a4 4 0 0 0 0 5.656l1.06-1.06Zm-1.06 1.06a4 4 0 0 0 5.657 0l-1.061-1.06a2.5 2.5 0 0 1-3.535 0l-1.061 1.06Zm7.07-7.07-.176-.177-1.06 1.06.176.178 1.06-1.061Z"
                    stroke-width="0"
                    fill="currentColor"
                  />
                </svg>
                {new URL(project.href).hostname}
              </p>
              <div class="absolute -inset-x-4 -inset-y-6 z-0 scale-95 bg-zinc-50 opacity-0 transition group-hover:scale-100 group-hover:opacity-100 sm:-inset-x-6 sm:rounded-2xl dark:bg-zinc-800/50" />
            </li>
          ))
        }
    </ul>
  </SimpleLayout>
</BaseLayout>
