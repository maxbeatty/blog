---
import type { GetStaticPathsOptions } from "astro";
import { getCollection } from "astro:content";
import PostList from "../components/PostList.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  return paginate(posts, { pageSize: 20 });
}

const { page } = Astro.props;
---

<BaseLayout
  title={page.currentPage === 1
    ? "Max Beatty"
    : `Page ${page.currentPage} - Max Beatty`}
>
  <h1>Max Beatty</h1>
  <PostList posts={page.data} />
  <nav
    class="mt-8 flex items-center justify-between border-t border-gray-200 pt-4"
  >
    {
      page.url.prev && (
        <a href={page.url.prev} class="text-blue-600 no-underline hover:underline">
          &larr; Newer
        </a>
      )
    }
    <span class="text-sm text-gray-500"
      >Page {page.currentPage} of {page.lastPage}</span
    >
    {
      page.url.next && (
        <a href={page.url.next} class="text-blue-600 no-underline hover:underline">
          Older &rarr;
        </a>
      )
    }
  </nav>
</BaseLayout>
