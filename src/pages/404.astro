---
import BaseLayout from "../layouts/BaseLayout.astro";
import SimpleLayout from "../components/SimpleLayout.astro";
---

<BaseLayout title="Not Found - Max Beatty">
  <SimpleLayout
    title="404"
    intro="Page not found. The page you're looking for doesn't exist."
  >
    <a
      href="/"
      class="text-sm font-medium text-sky-500 transition hover:text-sky-600 dark:text-sky-400 dark:hover:text-sky-300"
    >
      &larr; Go home
    </a>
  </SimpleLayout>
</BaseLayout>
