---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import Container from "../components/Container.astro";
import { slugify } from "../lib/slugify";

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const { title, date, categories, tags, featuredImage } = post.data;
const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout
  title={title}
  description={title}
  image={featuredImage}
  type="article"
  publishedTime={date}
>
  <Container class="mt-16 lg:mt-32">
    <div class="xl:relative">
      <div class="mx-auto max-w-2xl">
        <a
          href="/articles/"
          aria-label="Go back to articles"
          class="group mb-8 flex size-10 items-center justify-center rounded-full bg-white shadow-md ring-1 shadow-zinc-800/5 ring-zinc-900/5 transition lg:absolute lg:-left-5 lg:-mt-2 lg:mb-0 xl:-top-1.5 xl:left-0 xl:mt-0 dark:border dark:border-zinc-700/50 dark:bg-zinc-800 dark:ring-0 dark:ring-white/10 dark:hover:border-zinc-700 dark:hover:ring-white/20"
        >
          <svg
            viewBox="0 0 16 16"
            fill="none"
            aria-hidden="true"
            class="size-4 stroke-zinc-500 transition group-hover:stroke-zinc-700 dark:stroke-zinc-500 dark:group-hover:stroke-zinc-400"
          >
            <path
              d="M7.25 11.25 3.75 8m0 0 3.5-3.25M3.75 8h8.5"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
        <article>
          <header class="flex flex-col">
            <h1
              class="mt-6 text-4xl font-semibold tracking-tight text-zinc-800 sm:text-5xl text-pretty dark:text-zinc-100"
            >
              {title}
            </h1>
            <time
              datetime={date.toISOString()}
              class="order-first flex items-center text-base text-zinc-400 dark:text-zinc-500"
            >
              <span
                class="h-4 w-0.5 rounded-full bg-zinc-200 dark:bg-zinc-500"
              ></span>
              <span class="ml-3">{formattedDate}</span>
            </time>
          </header>
          <div class="prose mt-8 max-w-[65ch]">
            <slot />
          </div>
          {
            (categories.length > 0 || tags.length > 0) && (
              <footer class="mt-12 border-t border-zinc-100 pt-6 dark:border-zinc-700/40">
                {categories.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {categories.map((c) => (
                      <a
                        href={`/categories/${slugify(c)}/`}
                        class="rounded-full bg-zinc-100 px-3 py-1 text-sm text-zinc-600 transition hover:bg-zinc-200 dark:bg-zinc-800 dark:text-zinc-400 dark:hover:bg-zinc-700"
                      >
                        {c}
                      </a>
                    ))}
                  </div>
                )}
                {tags.length > 0 && (
                  <div class="mt-4 flex flex-wrap gap-2">
                    {tags.map((t) => (
                      <a
                        href={`/tags/${slugify(t)}/`}
                        class="text-sm text-zinc-400 transition hover:text-sky-500 dark:text-zinc-500 dark:hover:text-sky-400"
                      >
                        #{t}
                      </a>
                    ))}
                  </div>
                )}
              </footer>
            )
          }
        </article>
      </div>
    </div>
  </Container>
</BaseLayout>
