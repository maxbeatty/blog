---
import type { CollectionEntry } from "astro:content";

interface Props {
  posts: CollectionEntry<"posts">[];
  showYear?: boolean;
}

const { posts, showYear = true } = Astro.props;
---

<ul role="list" class="space-y-2">
  {
    posts.map((post) => (
      <li class="flex gap-4">
        <time
          datetime={post.data.date.toISOString()}
          class="w-20 shrink-0 tabular-nums text-sm text-zinc-400 dark:text-zinc-500"
        >
          {post.data.date.toLocaleDateString("en-US", {
            year: showYear ? "numeric" : undefined,
            month: "short",
            day: "numeric",
          })}
        </time>
        <a
          href={`/${post.id}/`}
          class="text-sm text-zinc-800 transition hover:text-sky-500 dark:text-zinc-200 dark:hover:text-sky-400"
        >
          {post.data.title}
        </a>
      </li>
    ))
  }
</ul>
